                        ],
                        "items": {
                            "type": "string"
                        },
                        "type": "array",
                        "uniqueItems": false
                    }
                },
                "type": "object"
            },
            "github_com_ryan-truong_kms-wrapper_pkg_types.SignResponse": {
                "properties": {
