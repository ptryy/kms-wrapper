VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=change-me
KMS_GATEWAY_TOKEN=change-me
KMS_GATEWAY_ADDR=127.0.0.1:8080
# Optional: comma-separated CIDRs whose X-Forwarded-* headers are honoured.
# KMS_GATEWAY_TRUSTED_PROXIES=
# Optional: canonical externally-reachable URL used in OpenAPI servers[].url.
# KMS_GATEWAY_PUBLIC_URL=
# Set to "true" to relax weak-token / non-loopback-swagger guards for local dev.
# KMS_DEV=true
